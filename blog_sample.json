100%;\n            height: 100%;\n            text-align: center;\n            transition: transform 0.6s;\n            transform-style: preserve-3d;\n        }\n\n        .ds-flash-card.flipped { transform: rotateY(180deg); }\n\n        .ds-flash-face {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            backface-visibility: hidden;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            padding: 2rem;\n            border: 1px solid var(--gray-light);\n            border-radius: 8px;\n            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);\n            background: var(--white);\n        }\n\n        .ds-flash-front { border-top: 6px solid var(--navy); }\n        .ds-flash-back { \n            background: var(--navy); \n            color: var(--white); \n            transform: rotateY(180deg); \n            border-top: 6px solid var(--gold);\n        }\n\n        .ds-flash-controls {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 1.5rem;\n            align-items: center;\n        }\n\n        .ds-btn-circle {\n            width: 50px; height: 50px;\n            border-radius: 50%;\n            border: 2px solid var(--navy);\n            background: transparent;\n            color: var(--navy);\n            font-size: 1.5rem;\n            cursor: pointer;\n            transition: all 0.2s;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .ds-btn-circle:hover { background: var(--navy); color: var(--white); }\n\n        \/* CTA *\/\n        .ds-cta {\n            background: var(--navy);\n            color: var(--white);\n            text-align: center;\n            padding: 6rem 2rem;\n            margin-top: 4rem;\n            border-radius: 8px;\n        }\n\n        .ds-btn {\n            display: inline-block;\n            background: var(--gold);\n            color: var(--navy);\n            padding: 1rem 3rem;\n            text-decoration: none;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            margin-top: 2rem;\n            transition: transform 0.2s;\n            box-shadow: 0 4px 6px rgba(0,0,0,0.2);\n        }\n\n        .ds-btn:hover { transform: translateY(-2px); background: #e5c14d; }\n\n        \/* Footer *\/\n        footer {\n            background: var(--navy);\n            color: var(--off);\n            text-align: center;\n            padding: 4rem 2rem;\n            font-size: 0.9rem;\n        }\n\n        \/* Utility *\/\n        #scroll-top {\n            position: fixed;\n            bottom: 30px; right: 30px;\n            width: 50px; height: 50px;\n            background: var(--gold);\n            border: none;\n            border-radius: 50%;\n            cursor: pointer;\n            font-size: 1.5rem;\n            opacity: 0;\n            transition: opacity 0.3s;\n            pointer-events: none;\n            color: var(--navy);\n        }\n        #scroll-top.show { opacity: 1; pointer-events: auto; }\n\n        @media (max-width: 768px) {\n            header { padding-top: 6rem; }\n            .ds-nav { overflow-x: auto; justify-content: flex-start; padding-left: 1rem; }\n            .ds-nav-list { flex-wrap: nowrap; }\n            .ds-nav-link { white-space: nowrap; }\n        }\n    <\/style>\n<\/head>\n<body>\n\n    <!-- Progress Bar -->\n    <div style=\"position:fixed; top:0; left:0; height:4px; background:var(--gold); width:0%; z-index:1000;\" id=\"progress-bar\"><\/div>\n    \n    <!-- Scroll Top -->\n    <button id=\"scroll-top\">\u2191<\/button>\n\n    <!-- Header -->\n    <header>\n        <canvas id=\"ds-particles\"><\/canvas>\n        <div class=\"ds-container\" style=\"position: relative; z-index: 2;\">\n            <div class=\"ds-badge\">NSTC 2026 Vision<\/div>\n            <h1>The Future of Learning is <br>Deep Science<\/h1>\n            <p style=\"color: var(--off); opacity: 0.9; margin: 0 auto; max-width: 700px;\">\n                Redefining STEM Education in India with the precise convergence of Nanotechnology, Biotechnology, and Artificial Intelligence.\n            <\/p>\n        <\/div>\n    <\/header>\n\n    <!-- Nav -->\n    <nav class=\"ds-nav\">\n        <div class=\"ds-container ds-nav-list\">\n            <a href=\"#convergence\" class=\"ds-nav-link\">Convergence<\/a>\n            <a href=\"#pedagogy\" class=\"ds-nav-link\">Pedagogy<\/a>\n            <a href=\"#careers\" class=\"ds-nav-link\">Careers<\/a>\n            <a href=\"#mastery\" class=\"ds-nav-link\">Mastery Deck<\/a>\n            <a href=\"#faq\" class=\"ds-nav-link\">FAQ<\/a>\n            <a href=\"#roadmap\" class=\"ds-nav-link\">Roadmap<\/a>\n        <\/div>\n    <\/nav>\n\n    <div class=\"ds-container\">\n        \n        <!-- Summary -->\n        <div class=\"ds-summary\">\n            <h3 style=\"margin-top:0; color:var(--navy);\">Executive Summary<\/h3>\n            <ul class=\"ds-check-list\">\n                <li><strong>NanoSchool (NSTC):<\/strong> Global deep science initiative (30k+ learners, 95+ countries).<\/li>\n                <li><strong>Convergence:<\/strong> The intersection of Nano, Bio, and AI is the key trend for 2026.<\/li>\n                <li><strong>Nano Industrial Finesse:<\/strong> Preparing participants for high-tech industrial careers.<\/li>\n                <li><strong>Advance Nano Virtuosity:<\/strong> Training in scientific writing &#038; patent commercialization.<\/li>\n                <li><strong>Pedagogy:<\/strong> Shifting to &#8220;Joyful, Meaningful, and Mindful&#8221; learning models.<\/li>\n            <\/ul>\n        <\/div>\n\n        <!-- Video -->\n        <section style=\"padding-top: 0; border: none;\">\n            <div class=\"ds-media-frame\">\n                <div class=\"ds-aspect-16-9\">\n                    <iframe src=\"https:\/\/www.youtube.com\/embed\/5oUQQPcDuVQ\" title=\"NanoSchool Deep Science\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen><\/iframe>\n                <\/div>\n            <\/div>\n        <\/section>\n\n        <!-- Intro Text -->\n        <section>\n            <p>For the last decade, the standard advice given to ambitious students was simple: &#8220;Learn to code.&#8221; It was the golden ticket to career security. But as we approach 2026, the ground is shifting beneath our feet. We are moving past the era of general digital literacy into the age of <strong>Deep Science<\/strong>\u2014a sophisticated convergence where <strong>Nanotechnology<\/strong>, <strong>Biotechnology<\/strong>, and <strong>Artificial Intelligence (AI)<\/strong> intersect to solve humanity&#8217;s most complex problems.<\/p>\n            <p>In this new ecosystem, holding a traditional degree is no longer enough. The market demands &#8220;stackable micro-credentials,&#8221; specific industrial skills, and the ability to navigate the invisible &#8220;nanoscale frontier.&#8221;<\/p>\n            <p>At the forefront of this revolution in India is <strong>NanoSchool<\/strong>, a flagship learning initiative of the <strong>Nano Science and Technology Consortium (NSTC)<\/strong>. Since 2006, NanoSchool has empowered over 30,000 learners across 95+ countries, bridging the critical gap between theoretical academic research and industrial scalability.<\/p>\n        <\/section>\n\n        <!-- 1. Convergence -->\n        <section id=\"convergence\">\n            <h2>1. The Era of Convergence: Where Nano, Bio, and AI Meet<\/h2>\n            <p>For decades, science education was compartmentalized&#8230; This is the domain of <strong>Deep Science<\/strong>.<\/p>\n            <p>According to strategic intelligence reports, the &#8220;Deep Science&#8221; ecosystem is driven by three pillars:<\/p>\n            \n            <div class=\"ds-grid-3\">\n                <div class=\"ds-card\">\n                    <h3>Nanotechnology<\/h3>\n                    <p>Manipulation of matter at the atomic scale (1\u2013100 nm). Innovations like self-healing coatings and targeted drug delivery are moving from theory to implementation.<\/p>\n                <\/div>\n                <div class=\"ds-card\">\n                    <h3>Biotechnology<\/h3>\n                    <p>Using cellular processes to develop technologies. By 2026, the focus is shifting toward &#8220;mechanistically aware&#8221; therapies.<\/p>\n                <\/div>\n                <div class=\"ds-card\">\n                    <h3>Artificial Intelligence<\/h3>\n                    <p>Utilizing Machine Learning to analyze vast datasets, predict molecular behavior, and automate complex tasks like protein folding.<\/p>\n                <\/div>\n            <\/div>\n\n            <div class=\"ds-summary\" style=\"margin-top: 2rem; background: #fff; border: 1px solid var(--navy); border-left: 6px solid var(--navy);\">\n                <h4 style=\"margin-top:0;\">Market Dynamics: The Shift to 2026<\/h4>\n                <p style=\"margin-bottom:0;\">By 2026, higher education will rely heavily on AI and XR. NanoSchool anticipates this shift with <strong>&#8220;Nano Industrial Finesse,&#8221;<\/strong> tailored for professionals in pharma and renewable energy.<\/p>\n            <\/div>\n        <\/section>\n\n        <!-- 2. Pedagogy -->\n        <section id=\"pedagogy\">\n            <h2>2. A Pedagogical Revolution<\/h2>\n            <p>To effectively teach these complex subjects, education must move beyond rote memorization. NanoSchool adopts a &#8220;Deep Learning&#8221; pedagogy:<\/p>\n            \n            <div class=\"ds-grid-3\">\n                <div class=\"ds-card\">\n                    <h4>Meaningful Learning<\/h4>\n                    <p>Connecting abstract concepts like <strong>SA\/V Ratio<\/strong> to real applications using <strong>Virtual Laboratories<\/strong>. Research confirms simulations are vital for grasping dynamic concepts.<\/p>\n                <\/div>\n                <div class=\"ds-card\">\n                    <h4>Joyful Learning<\/h4>\n                    <p>Active engagement through play. The <strong>Nano School Initiative<\/strong> utilizes kits and <strong>LEGO-Based Microscopy<\/strong> to visualize the &#8220;micro-world.&#8221;<\/p>\n                <\/div>\n                <div class=\"ds-card\">\n                    <h4>Mindful Learning<\/h4>\n                    <p>Fostering empathy and critical thinking. We encourage <strong>&#8220;textual dexterity&#8221;<\/strong>\u2014teaching students to scrutinize scientific papers and understand author purpose.<\/p>\n                <\/div>\n            <\/div>\n        <\/section>\n\n        <!-- 3. Careers -->\n        <section id=\"careers\">\n            <h2>3. Career Readiness: Bridging the &#8220;Valley of Death&#8221;<\/h2>\n            <p>A major challenge in technical education is the disconnect between academic degrees and employability. <strong>Nano Industrial Finesse<\/strong> closes this gap.<\/p>\n\n            <h3 style=\"margin-top: 2rem;\">High-Demand Skills for 2026<\/h3>\n            <div class=\"ds-table-wrap\">\n                <table>\n                    <thead>\n                        <tr>\n                            <th>Skill Cluster<\/th>\n                            <th>Specific Competencies<\/th>\n                            <th>NanoSchool Program<\/th>\n                        <\/tr>\n                    <\/thead>\n                    <tbody>\n                        <tr>\n                            <td><strong>Bioinformatics<\/strong><\/td>\n                            <td>RNA-seq, NGS, Molecular Docking<\/td>\n                            <td>Advance Bio-Nanotechnology<\/td>\n                        <\/tr>\n                        <tr>\n                            <td><strong>AI &#038; Data<\/strong><\/td>\n                            <td>Deep Learning for Structural Health (SHM)<\/td>\n                            <td>AI Masterclass Series<\/td>\n                        <\/tr>\n                        <tr>\n                            <td><strong>Tech Comms<\/strong><\/td>\n                            <td>Scientific Manuscript Writing<\/td>\n                            <td>Advance Nano Virtuosity<\/td>\n                        <\/tr>\n                        <tr>\n                            <td><strong>Manufacturing<\/strong><\/td>\n                            <td>Green Synthesis, Top-down Fabrication<\/td>\n                            <td>Nano-Synthesis &#038; Fabrication<\/td>\n                        <\/tr>\n                    <\/tbody>\n                <\/table>\n            <\/div>\n        <\/section>\n\n        <!-- PDF Mastery Deck -->\n        <section id=\"mastery\">\n            <h2>Deep Science Mastery: Micro to Macro<\/h2>\n            <p>Explore the detailed presentation deck covering the pedagogical shift.<\/p>\n            <div class=\"ds-media-frame\">\n                <iframe src=\"https:\/\/storage.googleapis.com\/nanoschool-in-website-wp-media-to-gcp-offload\/2026\/01\/cec3a1bd-micro_to_macro_deep_science_mastery.pdf\" style=\"width:100%; height:600px; border:none;\" title=\"Mastery Deck\"><\/iframe>\n            <\/div>\n        <\/section>\n\n        <!-- 4. Clusters (AEO) -->\n        <section id=\"clusters\">\n            <h2>4. Strategic Keyword Clusters<\/h2>\n            \n            <details open>\n                <summary>Cluster A: AI and Planetary Exploration<\/summary>\n                <div class=\"ds-faq-content\">\n                    <strong>Target:<\/strong> Aerospace Engineers, Geologists.<br>\n                    <strong>Mission:<\/strong> Automating detection of craters on the Moon\/Mars using U-Net and Faster R-CNN.<br>\n                    <strong>Why:<\/strong> Critical for upcoming ISRO\/NASA lunar operations.\n                <\/div>\n            <\/details>\n\n            <details>\n                <summary>Cluster B: Nanomedicine &#038; Drug Delivery<\/summary>\n                <div class=\"ds-faq-content\">\n                    <strong>Target:<\/strong> Pharmacologists, Biotech Students.<br>\n                    <strong>Learning:<\/strong> Designing nanocarriers to cross the Blood-Brain Barrier (BBB).<br>\n                    <strong>Why:<\/strong> Addressing the patent cliff (2026-2029) in Big Pharma.\n                <\/div>\n            <\/details>\n\n            <details>\n                <summary>Cluster C: Green Nanotechnology<\/summary>\n                <div class=\"ds-faq-content\">\n                    <strong>Target:<\/strong> Environmental Engineers.<br>\n                    <strong>Learning:<\/strong> Extracting nanomaterials from waste (Circular Economy).<br>\n                    <strong>Why:<\/strong> Meeting strict 2026 environmental regulations.\n                <\/div>\n            <\/details>\n        <\/section>\n\n        <!-- 5. FAQ -->\n        <section id=\"faq\">\n            <h2>5. AEO: Your Questions Answered<\/h2>\n            \n            <details>\n                <summary>Difference between Nanoscience and Nanotechnology?<\/summary>\n                <div class=\"ds-faq-content\">Nanoscience is the study of phenomena at atomic scales. Nanotechnology is the application of this knowledge to create devices.<\/div>\n            <\/details>\n            <details>\n                <summary>How does AI help in drug discovery?<\/summary>\n                <div class=\"ds-faq-content\">AI accelerates discovery through in-silico modeling, analyzing libraries to predict interactions and reduce lab time.<\/div>\n            <\/details>\n            <details>\n                <summary>Is nanotechnology safe for the environment?<\/summary>\n                <div class=\"ds-faq-content\">It offers bioremediation solutions but requires &#8220;Safe-by-Design&#8221; principles to manage nanotoxicity risks.<\/div>\n            <\/details>\n            <details>\n                <summary>What is Deep Learning in Structural Health Monitoring?<\/summary>\n                <div class=\"ds-faq-content\">Using AI to analyze sensor data from infrastructure to detect micro-cracks before failure occurs.<\/div>\n            <\/details>\n        <\/section>\n\n        <!-- 6. Flashcards -->\n        <section id=\"flashcards\">\n            <h2>6. Knowledge Reinforcement<\/h2>\n            <div class=\"ds-flash-container\" id=\"dsFlashContainer\">\n                <div class=\"ds-flash-card\" id=\"dsFlashCard\">\n                    <div class=\"ds-flash-face ds-flash-front\">\n                        <span style=\"color:var(--gold); text-transform:uppercase; letter-spacing:1px; font-size:0.8rem; margin-bottom:1rem;\">Question<\/span>\n                        <h3 id=\"dsQuestion\" style=\"margin:0;\">Loading&#8230;<\/h3>\n                    <\/div>\n                    <div class=\"ds-flash-face ds-flash-back\">\n                        <span style=\"color:var(--white); opacity:0.7; text-transform:uppercase; letter-spacing:1px; font-size:0.8rem; margin-bottom:1rem;\">Answer<\/span>\n                        <h3 id=\"dsAnswer\" style=\"margin:0; color:var(--white);\">Loading&#8230;<\/h3>\n                    <\/div>\n                <\/div>\n            <\/div>\n            <div class=\"ds-flash-controls\">\n                <button class=\"ds-btn-circle\" id=\"dsPrev\">\u2190<\/button>\n                <span id=\"dsCounter\" style=\"font-weight:600;\">1 \/ 19<\/span>\n                <button class=\"ds-btn-circle\" id=\"dsNext\">\u2192<\/button>\n            <\/div>\n        <\/section>\n\n        <!-- 7. Roadmap -->\n        <section id=\"roadmap\" style=\"border-bottom:none;\">\n            <h2>7. The 2026 Roadmap<\/h2>\n            <div class=\"ds-grid-3\">\n                <div class=\"ds-card\">\n                    <h4>The Recruitment Cycle<\/h4>\n                    <p>Starts <strong>Late Fall 2025<\/strong>. Prepare with CRISPR\/NGS workshops and hands-on projects.<\/p>\n                <\/div>\n                <div class=\"ds-card\">\n                    <h4>Global Hotspots<\/h4>\n                    <p>Look to <strong>India<\/strong>, Switzerland, and Singapore as critical innovation hubs.<\/p>\n                <\/div>\n                <div class=\"ds-card\">\n                    <h4>Conclusion<\/h4>\n                    <p>The future belongs to those who can navigate the Deep Science ecosystem. NanoSchool is your career accelerator.<\/p>\n                <\/div>\n            <\/div>\n        <\/section>\n\n        <!-- CTA -->\n        <div class=\"ds-cta\">\n            <h2 style=\"color:var(--white); margin-top:0;\">Ready to Navigate the Frontier?<\/h2>\n            <p style=\"color:rgba(255,255,255,0.8); margin:0 auto; max-width:600px;\">Join over 30,000 learners building the future of Deep Science.<\/p>\n            <a href=\"https:\/\/nanoschool.in\" class=\"ds-btn\">Explore Programs<\/a>\n        <\/div>\n\n    <\/div>\n\n    <footer>\n        <p>&copy; 2006-2026 Nano Science and Technology Consortium (NSTC). All Rights Reserved.<\/p>\n    <\/footer>\n\n    <script>\n        \/\/ --- DATA: Flashcards ---\n        const flashData = [\n            {q: \"What is NanoSchool?\", a: \"The deep science learning initiative by the Nano Science and Technology Consortium (NSTC).\"},\n            {q: \"Since when has NSTC been active?\", a: \"Since 2006.\"},\n            {q: \"What are the 3 primary domains?\", a: \"Nano Science, Artificial Intelligence (AI), and Biotechnology.\"},\n            {q: \"What is 'Nano Industrial Finesse'?\", a: \"A program to prepare participants for careers in Nanoscience technology industries.\"},\n            {q: \"What does 'Advance Nano Virtuosity' teach?\", a: \"Strong technical and scientific writing skills for documentation.\"},\n            {q: \"What is the 'Vaccinology' course about?\", a: \"Science, Innovation, and Global Impact of vaccines.\"},\n            {q: \"What is a 'Flexbook'?\", a: \"Free electronic modules for teachers and students (National NanoFlexbook).\"},\n            {q: \"How does 'Mindful Learning' view mistakes?\", a: \"As opportunities for growth, not failures.\"},\n            {q: \"What happens to SA\/V ratio at nanoscale?\", a: \"The surface-area-to-volume ratio increases significantly.\"},\n            {q: \"What is the 'Patent Commercialization' service?\", a: \"A service to help inventors with intellectual property.\"},\n            {q: \"What does the Telemedicine course focus on?\", a: \"Designing the 'Digital Health Wave'.\"},\n            {q: \"What is the 'Visiting Faculty' program?\", a: \"Involves external experts as faculty for courses.\"},\n            {q: \"How many countries has NanoSchool reached?\", a: \"Over 95 countries.\"},\n            {q: \"What 9th Grade concepts were chosen?\", a: \"Size\/Scale and Surface-Area-to-Volume Ratio.\"},\n            {q: \"What is the goal of the Nano School Initiative?\", a: \"Provide educational products like kits and games.\"},\n            {q: \"What is Self-Assembly?\", a: \"Particles at nanoscale spontaneously organizing into ordered structures.\"},\n            {q: \"Which country integrated Nano education early (2003)?\", a: \"Taiwan.\"},\n            {q: \"What key recommendation was made for NSE materials?\", a: \"Creating a central website registry for NSE materials.\"},\n            {q: \"What is the Sci\/Tech Writing objective?\", a: \"Equipping learners with skills to produce professional scientific documents.\"}\n        ];\n\n        \/\/ --- LOGIC ---\n        document.addEventListener('DOMContentLoaded', () => {\n            \/\/ Flashcards\n            let currentIndex = 0;\n            const card = document.getElementById('dsFlashCard');\n            const qEl = document.getElementById('dsQuestion');\n            const aEl = document.getElementById('dsAnswer');\n            const countEl = document.getElementById('dsCounter');\n\n            function loadCard(i) {\n                card.classList.remove('flipped');\n                setTimeout(() => {\n                    qEl.innerText = flashData[i].q;\n                    aEl.innerText = flashData[i].a;\n                    countEl.innerText = `${i + 1} \/ ${flashData.length}`;\n                }, 300);\n            }\n\n            document.getElementById('dsFlashContainer').addEventListener('click', () => card.classList.toggle('flipped'));\n            document.getElementById('dsNext').addEventListener('click', () => {\n                currentIndex = (currentIndex + 1) % flashData.length;\n                loadCard(currentIndex);\n            });\n            document.getElementById('dsPrev').addEventListener('click', () => {\n                currentIndex = (currentIndex - 1 + flashData.length) % flashData.length;\n                loadCard(currentIndex);\n            });\n\n            loadCard(0);\n\n            \/\/ Scroll Top\n            const scrollBtn = document.getElementById('scroll-top');\n            window.addEventListener('scroll', () => {\n                \/\/ Progress Bar\n                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;\n                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;\n                const scrolled = (winScroll \/ height) * 100;\n                document.getElementById('progress-bar').style.width = scrolled + \"%\";\n\n                \/\/ Scroll Top Btn\n                if (winScroll > 400) scrollBtn.classList.add('show');\n                else scrollBtn.classList.remove('show');\n            });\n\n            scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));\n\n            \/\/ Particles (Subtle)\n            const canvas = document.getElementById('ds-particles');\n            const ctx = canvas.getContext('2d');\n            let w, h, particles = [];\n            \n            function initParticles() {\n                w = canvas.width = window.innerWidth;\n                h = canvas.height = window.innerHeight;\n                particles = [];\n                for(let i=0; i < (w < 600 ? 30 : 60); i++) {\n                    particles.push({\n                        x: Math.random() * w, y: Math.random() * h,\n                        vx: (Math.random() - 0.5) * 0.5, vy: (Math.random() - 0.5) * 0.5\n                    });\n                }\n            }\n            \n            function animateParticles() {\n                ctx.clearRect(0,0,w,h);\n                ctx.fillStyle = '#D4AF37';\n                particles.forEach((p, i) => {\n                    p.x += p.vx; p.y += p.vy;\n                    if(p.x < 0 || p.x > w) p.vx *= -1;\n                    if(p.y < 0 || p.y > h) p.vy *= -1;\n                    ctx.beginPath(); ctx.arc(p.x, p.y, 1.5, 0, Math.PI*2); ctx.fill();\n                    \n                    for(let j=i+1; j<particles.length; j++) {\n                        let p2 = particles[j];\n                        let dx = p.x - p2.x, dy = p.y - p2.y;\n                        let dist = Math.sqrt(dx*dx + dy*dy);\n                        if(dist < 100) {\n                            ctx.strokeStyle = `rgba(212, 175, 55, ${0.2 - dist\/500})`;\n                            ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p2.x, p2.y); ctx.stroke();\n                        }\n                    }\n                });\n                requestAnimationFrame(animateParticles);\n            }\n\n            window.addEventListener('resize', initParticles);\n            initParticles();\n            animateParticles();\n        });\n    <\/script>\n<\/body>\n<\/html>\n","protected":false},"excerpt":{"rendered":"<p>The Future of Learning is Deep Science: Redefining STEM Education | NanoSchool 2026 \u2191 NSTC 2026 Vision The Future of Learning is Deep Science Redefining STEM Education in India with the precise convergence of Nanotechnology, Biotechnology, and Artificial Intelligence. Convergence Pedagogy Careers Mastery Deck FAQ Roadmap Executive Summary NanoSchool (NSTC): Global deep science initiative (30k+ [&hellip;]<\/p>\n","protected":false},"featured_media":90732,"parent":0,"template":"","tags":[],"post_category":[],"class_list":["post-92742","nstc_blog","type-nstc_blog","status-publish","has-post-thumbnail","hentry","post-wrapper","thrv_wrapper"],"acf":[],"_links":{"self":[{"href":"https:\/\/nanoschool.in\/wp-json\/wp\/v2\/nstc_blog\/92742","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/nanoschool.in\/wp-json\/wp\/v2\/nstc_blog"}],"about":[{"href":"https:\/\/nanoschool.in\/wp-json\/wp\/v2\/types\/nstc_blog"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/nanoschool.in\/wp-json\/wp\/v2\/media\/90732"}],"wp:attachment":[{"href":"https:\/\/nanoschool.in\/wp-json\/wp\/v2\/media?parent=92742"}],"wp:term":[{"taxonomy":"post_tag","embeddable":true,"href":"https:\/\/nanoschool.in\/wp-json\/wp\/v2\/tags?post=92742"},{"taxonomy":"post_category","embeddable":true,"href":"https:\/\/nanoschool.in\/wp-json\/wp\/v2\/post_category?post=92742"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]},"_embedded":{"wp:featuredmedia":[{"id":90732,"date":"2026-01-10T15:58:08","slug":"1758485405066","type":"attachment","link":"https:\/\/nanoschool.in\/1758485405066\/","title":{"rendered":"1758485405066"},"author":4364,"featured_media":0,"acf":[],"caption":{"rendered":"<p>redefining STEM<\/p>\n"},"alt_text":"redefining STEM","media_type":"image","mime_type":"image\/png","media_details":{"width":1024,"height":576,"file":"2026\/01\/d40b4d1a-1758485405066.png","filesize":932847,"sizes":{"medium":{"file":"d40b4d1a-1758485405066-300x169.png","width":300,"h